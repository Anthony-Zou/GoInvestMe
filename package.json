{
  "name": "gim",
  "version": "1.0.0",
  "description": "Smart contract development with Hardhat",
  "type": "module",
  "scripts": {
    "compile": "npm run compile --prefix blockchain",
    "test": "npm run test --prefix blockchain",
    "test:coverage": "npm run test:coverage --prefix blockchain",
    "node": "npm run node --prefix blockchain",
    "deploy:sepolia": "npm run deploy:sepolia --prefix blockchain",
