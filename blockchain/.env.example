# ============================================================================
# GoInvestMe - Environment Variables Template
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (command: cp .env.example .env)
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git (already in .gitignore)
# 
# ============================================================================

# ============================================================================
# TESTNET CONFIGURATION (Sepolia)
# ============================================================================

# Your testnet deployer wallet private key
# Get from MetaMask: Settings → Security & Privacy → Show private key
# WARNING: This wallet will become the contract OWNER
SEPOLIA_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Alchemy RPC endpoint for Sepolia testnet
# Get from: https://dashboard.alchemy.com/
# 1. Sign up for free account
# 2. Create new app → Select "Ethereum" → Select "Sepolia"
# 3. Copy the HTTPS URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# Etherscan API key (for contract verification)
# Get from: https://etherscan.io/myapikey
# 1. Sign up for free account
# 2. Go to API Keys section
# 3. Create new API key
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ============================================================================
# MAINNET CONFIGURATION (Production - ONLY use with hardware wallet)
# ============================================================================

# MAINNET_PRIVATE_KEY=NEVER_PUT_MAINNET_KEY_IN_PLAIN_TEXT
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key_here

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# 
# ✅ DO:
# - Use separate wallet for testnet vs mainnet
# - Keep private keys in .env (ignored by Git)
# - Use hardware wallet for mainnet
# - Get professional audit before mainnet
# 
# ❌ NEVER:
# - Commit .env to Git
# - Share private keys in messages/screenshots
# - Use personal wallet with real funds for testing
# - Deploy to mainnet without audit
# 
# ============================================================================
